        TeamsMeetingConfiguration "TeamsMeetingConfiguration-Global"
        {
            ApplicationId                          = $ConfigurationData.NonNodeData.ApplicationId;
            CertificateThumbprint                  = $ConfigurationData.NonNodeData.CertificateThumbprint;
            ClientAppSharingPort                   = 50040;
            ClientAppSharingPortRange              = 20;
            ClientAudioPort                        = 50000;
            ClientAudioPortRange                   = 20;
            ClientMediaPortRangeEnabled            = $True;
            ClientVideoPort                        = 50020;
            ClientVideoPortRange                   = 20;
            CustomFooterText                       = "";
            DisableAnonymousJoin                   = $False;
            DisableAppInteractionForAnonymousUsers = $False;
            EnableQoS                              = $True; ### L3|Wir empfehlen, Quality of Service im internen Netzwerk zu implementieren.
            FeedbackSurveyForAnonymousUsers        = "Enabled";
            Identity                               = "Global";
            LegalURL                               = "Link zu Datenschutzhinweisen"; ### L3|Wir empfehlen, einen Link zu Datenschutzhinweisen in der E-Mail-Einladung zu ergänzen.
            LimitPresenterRolePermissions          = $False;
            TenantId                               = $OrganizationName;
        }

        TeamsMeetingPolicy "TeamsMeetingPolicy-Global"
        {
            AllowAnnotations                           = $True;
            AllowAnonymousUsersToDialOut               = $False; ### L2|Wir empfehlen, die Dial Out Funktion für anonyme Nutzer zu deaktivieren.
            AllowAnonymousUsersToJoinMeeting           = $True;
            AllowAnonymousUsersToStartMeeting          = $False; ### L2|Wir empfehlen, anonymen Nutzer nicht das Starten von Meeting zu gestatten.
            AllowBreakoutRooms                         = $True;
            AllowCartCaptionsScheduling                = "DisabledUserOverride";
            AllowChannelMeetingScheduling              = $True;
            AllowCloudRecording                        = $False; ### L1|Wir empfehlen, die Aufzeichnung von Meetings in der Global Policy zu unterbinden. Die Aufzeichnung sollte per separater Policy nur an berechtigte Mitarbeiter vergeben werden.
            AllowDocumentCollaboration                 = "Enabled";
            AllowEngagementReport                      = "Disabled"; ### L2|Wir empfehlen, den Engagement Report aus Datenschutzgründen zu deaktivieren.
            AllowExternalNonTrustedMeetingChat         = $True;
            AllowExternalParticipantGiveRequestControl = $False; ### L1|Wir empfehlen, die Übergabe der Steuerung nicht an externe Teilnehmer zuzulassen.
            AllowIPAudio                               = $True;
            AllowIPVideo                               = $True;
            AllowMeetingCoach                          = $True;
            AllowMeetingReactions                      = $True;
            AllowMeetingRegistration                   = $True;
            AllowMeetNow                               = $True;
            AllowNDIStreaming                          = $False;
            AllowNetworkConfigurationSettingsLookup    = $False;
            AllowOrganizersToOverrideLobbySettings     = $False;
            AllowOutlookAddIn                          = $True;
            AllowParticipantGiveRequestControl         = $True;
            AllowPowerPointSharing                     = $True;
            AllowPrivateMeetingScheduling              = $True;
            AllowPrivateMeetNow                        = $True;
            AllowPSTNUsersToBypassLobby                = $False;
            AllowRecordingStorageOutsideRegion         = $False;
            AllowSharedNotes                           = $True;
            AllowTranscription                         = $False; ### L2|Wir empfehlen, die Nutzung von Transcription in Meetings zu unterbinden, sofern kein Use Case (z.B. Nutzung von Copilot) vorliegt.
            AllowWatermarkForCameraVideo               = $True;
            AllowWatermarkForScreenSharing             = $True;
            AllowWhiteboard                            = $True; ### L3|Wir empfehlen, die Nutzung von Whiteboards in Meetings zu ermöglichen.
            ApplicationId                              = $ConfigurationData.NonNodeData.ApplicationId;
            AttendeeIdentityMasking                    = "DisabledUserOverride";
            AutoAdmittedUsers                          = "EveryoneInCompanyExcludingGuests"; ### L2|Wir empfehlen, das Umgehen der Lobby nur für Member der eigenen Organisation zuzulassen.
            AutomaticallyStartCopilot                  = "Disabled";
            AutoRecording                              = "Enabled";
            CaptchaVerificationForMeetingJoin          = "NotRequired";
            CertificateThumbprint                      = $ConfigurationData.NonNodeData.CertificateThumbprint;
            ChannelRecordingDownload                   = "Allow";
            ConnectToMeetingControls                   = "Enabled";
            ContentSharingInExternalMeetings           = "EnabledForAnyone";
            Copilot                                    = "EnabledWithTranscript";
            CopyRestriction                            = $True;
            Description                                = "ACMS auto updated Global";
            DesignatedPresenterRoleMode                = "EveryoneUserOverride";
            DetectSensitiveContentDuringScreenSharing  = $True;
            EnrollUserOverride                         = "Disabled";
            Ensure                                     = "Present";
            ExplicitRecordingConsent                   = "Enabled"; ### L1|Wir empfehlen, die explizite Zustimmung für Meeting-Aufzeichnungen zu nutzen, sofern die Aufzeichnung erlaubt ist.
            ExternalMeetingJoin                        = "EnabledForAnyone";
            Identity                                   = "Global";
            InfoShownInReportMode                      = "FullInformation";
            IPAudioMode                                = "EnabledOutgoingIncoming";
            IPVideoMode                                = "EnabledOutgoingIncoming";
            LiveCaptionsEnabledType                    = "DisabledUserOverride";
            LiveInterpretationEnabledType              = "DisabledUserOverride";
            LiveStreamingMode                          = "Disabled";
            MediaBitRateKb                             = 50000;
            MeetingChatEnabledType                     = "Enabled";
            NewMeetingRecordingExpirationDays          = 120;
            ParticipantNameChange                      = "Disabled"; ### L2|Wir empfehlen, die Änderung des eignenen Namens in Meetings zu unterbinden.
            PreferredMeetingProviderForIslandsMode     = "TeamsAndSfb";
            QnAEngagementMode                          = "Enabled";
            RoomAttributeUserOverride                  = "Off";
            RoomPeopleNameUserOverride                 = "Off";
            ScreenSharingMode                          = "EntireScreen";
            SpeakerAttributionMode                     = "EnabledUserOverride";
            StreamingAttendeeMode                      = "Disabled";
            TeamsCameraFarEndPTZMode                   = "Disabled";
            TenantId                                   = $OrganizationName;
            VideoFiltersMode                           = "AllFilters";
            VoiceIsolation                             = "Enabled";
            WhoCanRegister                             = "Everyone";
        }
        TeamsMessagingConfiguration "TeamsMessagingConfiguration"
        {
            ContentBasedPhishingCheck         = "Disabled";
            CustomEmojis                      = $False; ### L2|Wir empfehlen, den Upload von Custom Emojis zu unterbinden.
            EnableInOrganizationChatControl   = $False;
            EnableVideoMessageCaptions        = $True;
            FileTypeCheck                     = "Disabled";
            IsSingleInstance                  = "Yes";
            MessagingNotes                    = "Enabled";
            ReportIncorrectSecurityDetections = "Enabled";
            Storyline                         = "Enabled";
            TenantId                          = $OrganizationName;
            UrlReputationCheck                = "Disabled";
        }
        TeamsMessagingPolicy "TeamsMessagingPolicy-Global"
        {
            AllowChatWithGroup                            = $True;
            AllowCommunicationComplianceEndUserReporting  = $True;
            AllowCustomGroupChatAvatars                   = $True;
            AllowFluidCollaborate                         = $False;
            AllowFullChatPermissionUserToDeleteAnyMessage = $False;
