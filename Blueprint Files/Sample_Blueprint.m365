Configuration Sample_Blueprint
{
    param (
    )

    $OrganizationName = $ConfigurationData.NonNodeData.OrganizationName

    Import-DscResource -ModuleName 'Microsoft365DSC' -ModuleVersion '1.25.1015.1'

    Node localhost
    {
        ODSettings "ODSettings"
        {
            ApplicationId                             = $ConfigurationData.NonNodeData.ApplicationId;
            BlockMacSync                              = $False;
            CertificateThumbprint                     = $ConfigurationData.NonNodeData.CertificateThumbprint;
            DisableReportProblemDialog                = $False;
            DomainGuids                               = @("123e4567-e89b-12d3-a456-426614174000"); ### L2|Wir empfehlen, die Synchronisierung von OneDrive nur in der eigenen Domäne zu erlauben.
            Ensure                                    = "Present";
            ExcludedFileExtensions                    = @("exe", "bat"); ### L1|Wir empfehlen, den Upload von bestimmten Dateitypen in OneDrive zu unterbinden.
            IsSingleInstance                          = "Yes";
            NotificationsInOneDriveForBusinessEnabled = $True;
            ODBAccessRequests                         = "Unspecified";
            ODBMembersCanShare                        = "Unspecified";
            OneDriveForGuestsEnabled                  = $False;
            OneDriveStorageQuota                      = 1048576;
            OrphanedPersonalSitesRetentionPeriod      = 180; ### L3|Wir empfehlen, die Aufbewahrung von OneDrive Sites auf 180 Tage zu erhöhen.
            TenantId                                  = $OrganizationName;
            TenantRestrictionEnabled                  = $False;
        }
        SPOAccessControlSettings "SPOAccessControlSettings"
        {
            ApplicationId                 = $ConfigurationData.NonNodeData.ApplicationId;
            CertificateThumbprint         = $ConfigurationData.NonNodeData.CertificateThumbprint;
            ConditionalAccessPolicy       = "AllowLimitedAccess"; ### L2|Wir empfehlen, den Zugriff von nicht-verwalteten Geräten auf Online-Zugriff zu beschränken.
            DisallowInfectedFileDownload  = $True; ### L1|Wir empfehlen, den Download von infizierten Dateien zu verhindern.
            DisplayStartASiteOption       = $False; ### L2|Wir empfehlen, die Anlage von neuen Sites durch Nutzer zu beschränken.
            EmailAttestationReAuthDays    = 30;
            EmailAttestationRequired      = $False;
            EnableRestrictedAccessControl = $False;
            Ensure                        = "Present";
            ExternalServicesEnabled       = $True;
            IPAddressAllowList            = "";
            IPAddressEnforcement          = $False;
            IPAddressWACTokenLifetime     = 15;
            IsSingleInstance              = "Yes";
            TenantId                      = $OrganizationName;
        }
        SPOSharingSettings "SPOSharingSettings"
        {
            ApplicationId                            = $ConfigurationData.NonNodeData.ApplicationId;
            BccExternalSharingInvitations            = $False;
            CertificateThumbprint                    = $ConfigurationData.NonNodeData.CertificateThumbprint;
            DefaultLinkPermission                    = "View"; ### L2|Wir empfehlen, die Standard-Berechtigung für freigegebene Links auf "View" zu setzen.
            DefaultSharingLinkType                   = "Direct"; ### L1|Wir empfehlen, die Standard-Berechtigung für freigegebene Links auf "Bestimmte Personen" zu setzen.
            EnableGuestSignInAcceleration            = $False;
            Ensure                                   = "Present";
            ExternalUserExpirationRequired           = $True; ### L2|Wir empfehlen, den Gast-Zugriff auf Sites zeitlich zu begrenzen.
            ExternalUserExpireInDays                 = 90; ### L2|Wir empfehlen, die zeitliche Begrenzung für den Gastzugriff auf 90 Tage zu setzen.
            FileAnonymousLinkType                    = "Edit";
            FolderAnonymousLinkType                  = "Edit";
            IsSingleInstance                         = "Yes";
            MySiteSharingCapability                  = "Disabled"; ### L1|Wir empfehlen, die Freigabe von OneDrive nur innerhalb der Organisation zu erlauben.
            NotifyOwnersWhenItemsReshared            = $True;
            PreventExternalUsersFromResharing        = $True; ### L2|Wir empfehlen, das Teilen von Elementen durch Gäste zu verhindern.
            ProvisionSharedWithEveryoneFolder        = $False;
            SharingCapability                        = "ExistingExternalUserSharingOnly"; ### L1|Wir empfehlen, die Freigabe von SharePoint nur mit bestehenden Gästen zu erlauben.
            SharingDomainRestrictionMode             = "None";
            ShowAllUsersClaim                        = $False;
            ShowEveryoneClaim                        = $False;
            ShowEveryoneExceptExternalUsersClaim     = $True;
            ShowPeoplePickerSuggestionsForGuestUsers = $False;
            TenantId                                 = $OrganizationName;
        }
        SPOTenantSettings "SPOTenantSettings"
        {
            ApplicationId                                          = $ConfigurationData.NonNodeData.ApplicationId;
            ApplyAppEnforcedRestrictionsToAdHocRecipients          = $True;
            CertificateThumbprint                                  = $ConfigurationData.NonNodeData.CertificateThumbprint;
            CommentsOnSitePagesDisabled                            = $False;
            EnableAzureADB2BIntegration                            = $True;
            Ensure                                                 = "Present";
            ExemptNativeUsersFromTenantLevelRestricedAccessControl = $False;
            FilePickerExternalImageSearchEnabled                   = $True;
            HideDefaultThemes                                      = $False;
            IsSingleInstance                                       = "Yes";
            LegacyAuthProtocolsEnabled                             = $False; ### L1|Wir empfehlen, die Anmeldung von Anwendungen zu verhindern, die keine Modern Authentication unterstützen.
            MarkNewFilesSensitiveByDefault                         = "AllowExternalSharing";
            MaxCompatibilityLevel                                  = "15";
            MinCompatibilityLevel                                  = "15";
            NotificationsInSharePointEnabled                       = $True;
            OfficeClientADALDisabled                               = $False;
            OwnerAnonymousNotification                             = $True;
            PublicCdnAllowedFileTypes                              = "CSS,EOT,GIF,ICO,JPEG,JPG,JS,MAP,PNG,SVG,TTF,WOFF";
            PublicCdnEnabled                                       = $False;
            SearchResolveExactEmailOrUPN                           = $False;
            SignInAccelerationDomain                               = "";
            SocialBarOnSitePagesDisabled                           = $False;
            TenantDefaultTimezone                                  = "(UTC+01:00) Amsterdam, Berlin, Bern, Rome, Stockholm, Vienna"; ### L3|Wir empfehlen, die Standard-Zeitzone auf die lokale Zeitzone zu setzen.
            TenantId                                               = $OrganizationName;
            UseFindPeopleInPeoplePicker                            = $False;
            UsePersistentCookiesForExplorerView                    = $False;
        }
        TeamsAIPolicy "TeamsAIPolicy-Global"
        {
            EnrollFace                = "Disabled"; ### L2|Wir empfehlen, die Erstellung von Gesichts-Profilen zu unterbinden.
            EnrollVoice               = "Disabled"; ### L2|Wir empfehlen, die Erstellung von Sprach-Profilen zu unterbinden.
            Ensure                    = "Present";
            Identity                  = "Global";
            SpeakerAttributionForBYOD = "Enabled";
            TenantId                  = $OrganizationName;
        }
        TeamsCallingPolicy "TeamsCallingPolicy-Global"
        {
            AIInterpreter                        = "Enabled";
            AllowCallForwardingToPhone           = $True; ### L2|Wir empfehlen, die Weiterleitung an externe Nummern nur in begründeten Fällen zuzulassen.
            AllowCallForwardingToUser            = $True; ### L3|Wir empfehlen, die Weiterleitung an andere Nutzer zuzulassen.
            AllowCallGroups                      = $True; ### L3|Wir empfehlen, die Erstellung von Anrufgruppen zuzulassen.
            AllowCallRedirect                    = "Disabled";
            AllowCloudRecordingForCalls          = $False; ### L1|Wir empfehlen, die Aufzeichnung von privaten Anrufen nicht zuzulassen.
            AllowDelegation                      = $True; ### L3|Wir empfehlen, die Einrichtung von Stellvertretern zuzulassen.
            AllowPrivateCalling                  = $True; ### L3|Wir empfehlen, das Tätigen von Anrufen in Teams zuzulassen.
            AllowSIPDevicesCalling               = $False;
            AllowTranscriptionForCalling         = $False; ### L2|Wir empfehlen, die Transcription bei privaten Anrufen nur bei einem berechtigten Use Case (z.B. Nutzung von Copilot) zu erlauben.
            AllowVoicemail                       = "UserOverride"; ### L3|Wir empfehlen, die Einrichtung einer Voicemail dem Nutzer zu überlassen.
            AllowWebPSTNCalling                  = $True;
            ApplicationId                        = $ConfigurationData.NonNodeData.ApplicationId;
            AutoAnswerEnabledType                = "Disabled";
            BusyOnBusyEnabledType                = "UserOverride"; ### L3|Wir empfehlen, die Entscheidung für das "Besetzt"-Verhalten dem Nutzer zu überlassen.
            CallRecordingExpirationDays          = 60;
            CertificateThumbprint                = $ConfigurationData.NonNodeData.CertificateThumbprint;
            Copilot                              = "Enabled";
            EnableSpendLimits                    = $False;
            EnableWebPstnMediaBypass             = $False;
            Ensure                               = "Present";
            ExplicitRecordingConsent             = "Disabled";
            Identity                             = "Global";
            InboundFederatedCallRoutingTreatment = "RegularIncoming";
            InboundPstnCallRoutingTreatment      = "RegularIncoming";
            LiveCaptionsEnabledTypeForCalling    = "DisabledUserOverride";
            MusicOnHoldEnabledType               = "Enabled";
            PopoutForIncomingPstnCalls           = "Disabled";
            PreventTollBypass                    = $False;
            RealTimeText                         = "Enabled";
            ShowTeamsCallsInCallLog              = $True;
            SpamFilteringEnabledType             = "Enabled";
            TenantId                             = $OrganizationName;
            VoiceSimulationInInterpreter         = "Enabled";
        }
        TeamsCallParkPolicy "TeamsCallParkPolicy-Global"
        {
            AllowCallPark         = $False; ### L3|Wir empfehlen, kein Parken von Anrufen zuzulassen. Stattdessen sollte die Funktion "Transfer" genutzt werden.
            ApplicationId         = $ConfigurationData.NonNodeData.ApplicationId;
            CertificateThumbprint = $ConfigurationData.NonNodeData.CertificateThumbprint;
            Ensure                = "Present";
            Identity              = "Global";
            ParkTimeoutSeconds    = 300;
            PickupRangeEnd        = 99;
            PickupRangeStart      = 10;
            TenantId              = $OrganizationName;
        }
        TeamsClientConfiguration "TeamsClientConfiguration-Global"
        {
            AllowBox                         = $False; ### L1|Wir empfehlen, die Nutzung von 3rd Party Speicherdiensten in Teams zu unterbinden.
            AllowDropBox                     = $False; ### L1|Wir empfehlen, die Nutzung von 3rd Party Speicherdiensten in Teams zu unterbinden.
            AllowEgnyte                      = $False; ### L1|Wir empfehlen, die Nutzung von 3rd Party Speicherdiensten in Teams zu unterbinden.
            AllowEmailIntoChannel            = $False; ### L1|Wir empfehlen, die Email-Integration zu deaktivieren.
            AllowGoogleDrive                 = $False; ### L1|Wir empfehlen, die Nutzung von 3rd Party Speicherdiensten in Teams zu unterbinden.
            AllowGuestUser                   = $True;
            AllowOrganizationTab             = $True; ### L3|Wir empfehlen, die Nutzung des Organization Tabs zu erlauben, sofern die Manager-Struktur im AD gepflegt ist.
            AllowResourceAccountSendMessage  = $True;
            AllowRoleBasedChatPermissions    = $False;
            AllowScopedPeopleSearchandAccess = $False; ### L2|Wir empfehlen, die Teams-Suche an die Globale Addressliste (GAL) anzupassen.
            AllowShareFile                   = $False; ### L1|Wir empfehlen, die Nutzung von 3rd Party Speicherdiensten in Teams zu unterbinden.
            AllowSkypeBusinessInterop        = $True;
            ApplicationId                    = $ConfigurationData.NonNodeData.ApplicationId;
            CertificateThumbprint            = $ConfigurationData.NonNodeData.CertificateThumbprint;
            ContentPin                       = "RequiredOutsideScheduleMeeting";
            Identity                         = "Global";
            ResourceAccountContentAccess     = "NoAccess";
            TenantId                         = $OrganizationName;
        }
        TeamsEnhancedEncryptionPolicy "TeamsEnhancedEncryptionPolicy-Global"
        {
            ApplicationId                        = $ConfigurationData.NonNodeData.ApplicationId;
            CallingEndtoEndEncryptionEnabledType = "DisabledUserOverride"; ### L1|Wir empfehlen, die Nutzung von Ende-zu-Ende Verschlüsselung zu ermöglichen.
            CertificateThumbprint                = $ConfigurationData.NonNodeData.CertificateThumbprint;
            Ensure                               = "Present";
            Identity                             = "Global";
            MeetingEndToEndEncryption            = "DisabledUserOverride"; ### L1|Wir empfehlen, die Nutzung von Ende-zu-Ende Verschlüsselung zu ermöglichen.
            TenantId                             = $OrganizationName;
        }
        TeamsEventsPolicy "TeamsEventsPolicy-Global"
        {
            AllowedQuestionTypesInRegistrationForm  = "AllQuestions";
            AllowedTownhallTypesForRecordingPublish = "Everyone";
            AllowedWebinarTypesForRecordingPublish  = "Everyone";
            AllowEmailEditing                       = "Enabled";
            AllowEventIntegrations                  = $True;
            AllowTownhalls                          = "Disabled"; ### L2|Wir empfehlen, die Erstellung von Town Halls in der Global Policy zu deaktivieren und stattdessen separate Policies für berechtigte Mitarbeiter zu erstellen.
            AllowWebinars                           = "Disabled"; ### L2|Wir empfehlen, die Erstellung von Webinaren in der Global Policy zu deaktivieren und stattdessen separate Policies für berechtigte Mitarbeiter zu erstellen.
            ApplicationId                           = $ConfigurationData.NonNodeData.ApplicationId;
            BroadcastPremiumApps                    = "Enabled";
            CertificateThumbprint                   = $ConfigurationData.NonNodeData.CertificateThumbprint;
            Description                             = "Default policy";
            Ensure                                  = "Present";
            EventAccessType                         = "Everyone";
            Identity                                = "Global";
            ImmersiveEvents                         = "Enabled";
            RecordingForTownhall                    = "Enabled";
            RecordingForWebinar                     = "Enabled";
            TenantId                                = $OrganizationName;
            TownhallChatExperience                  = "Optimized";
            TownhallEventAttendeeAccess             = "Everyone";
            TranscriptionForTownhall                = "Enabled";
            TranscriptionForWebinar                 = "Enabled";
            UseMicrosoftECDN                        = $True;
        }
        TeamsFederationConfiguration "TeamsFederationConfiguration-Global"
        {
            AllowedDomains                              = @("Whitelist"); ### L2|Wir empfehlen, die Kommunikation nur mit Tenants zu erlauben, die per Whitelist freigeschaltet sind.
            AllowFederatedUsers                         = $True;
            AllowTeamsConsumer                          = $False; ### L2|Wir empfehlen, die Kommunikation mit privaten Teams-Konten zu unterbinden.
