            Identity                                    = "Global";
            RestrictTeamsConsumerToExternalUserProfiles = $False;
            SharedSipAddressSpace                       = $False;
            TenantId                                    = $OrganizationName;
            TreatDiscoveredPartnersAsUnverified         = $False;
        }
        TeamsFeedbackPolicy "TeamsFeedbackPolicy-Global"
        {
            AllowEmailCollection      = $False; ### L3|Wir empfehlen, die Feeback-Funktionen zu deaktivieren.
            AllowLogCollection        = $False; ### L3|Wir empfehlen, die Feeback-Funktionen zu deaktivieren.
            AllowScreenshotCollection = $False; ### L3|Wir empfehlen, die Feeback-Funktionen zu deaktivieren.
            Ensure                    = "Present";
            Identity                  = "Global";
            ReceiveSurveysMode        = "Disabled"; ### L3|Wir empfehlen, die Feeback-Funktionen zu deaktivieren.
            TenantId                  = $OrganizationName;
            UserInitiatedMode         = "Disabled"; ### L3|Wir empfehlen, die Feeback-Funktionen zu deaktivieren.
        }
        TeamsFilesPolicy "TeamsFilesPolicy-Global"
        {
            Ensure                              = "Present";
            FileSharingInChatswithExternalUsers = "Disabled"; ### L2|Wir empfehlen, das Teilen von Dateien in externen Chats zu verhindern.
            Identity                            = "Global";
            NativeFileEntryPoints               = "Enabled";
            SPChannelFilesTab                   = "Enabled";
